  "requirements": "5+ years experience in Node.js",
  "responsibilities": "Design and implement APIs",
  "location": "Cairo, Egypt",
  "salaryMin": 15000,
  "salaryMax": 25000,
  "jobType": "FULL_TIME",
  "workPreference": "REMOTE",
  "experienceLevel": "SENIOR",
  "deadline": "2026-03-15",
  "skillNames": ["Node.js", "TypeScript", "PostgreSQL"]
}
```

