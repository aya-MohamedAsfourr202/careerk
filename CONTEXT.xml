import { Transform, Type } from 'class-transformer';
import {
  IsString,
  IsOptional,
  IsNumber,
  IsBoolean,
  IsArray,
  ValidateNested,
  IsDateString,
  IsEnum,
} from 'class-validator';
import { AvailabilityStatusEnum, DegreeTypeEnum, WorkPreferenceEnum } from 'generated/prisma/enums';

class PersonalInfoDto {
