    "statusCode": 401,
    "timestamp": "2026-02-17T08:00:00.000Z",
    "path": "/cv/me",
    "method": "DELETE"
  }
}
```

### 403 Forbidden - Insufficient Permissions

```json
{
  "success": false,
  "error": {
    "message": "Forbidden resource",
    "statusCode": 403,
    "timestamp": "2026-02-17T08:00:00.000Z",
